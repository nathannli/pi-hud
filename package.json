{
  "name": "pi-hud",
  "version": "0.1.0",
  "description": "A persistent hud for Pi with context, project, and subagent status.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludevdot/pi-hud.git"
  },
  "packageManager": "pnpm@10.30.2",
  "keywords": [
    "pi-package",
    "pi",
    "hud",
    "tui",
    "coding-agent"
  ],
  "files": [
    "extensions",
    "assets",
    "README.md",
    "LICENSE",
    "scripts"
  ],
  "scripts": {
    "test": "vitest --run",
    "pack:dry": "pnpm pack --dry-run",
    "verify:package": "node scripts/verify-package-files.mjs",
    "prepack": "pnpm test && pnpm run verify:package",
    "prepublishOnly": "pnpm test && pnpm run verify:package"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "image": "https://cdn.jsdelivr.net/npm/pi-hud/assets/pi-hud.jpeg"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.74.1",
    "@earendil-works/pi-coding-agent": "0.74.1",
    "@earendil-works/pi-tui": "0.74.1",
    "vitest": "3.2.4",
    "tsx": "4.20.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
