{
  "name": "pi-hud",
  "version": "0.4.4",
  "description": "Persistent HUD extension for Pi showing project, context, MCP, git, and subagent status.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludevdot/pi-hud.git"
  },
  "homepage": "https://github.com/ludevdot/pi-hud#readme",
  "bugs": {
    "url": "https://github.com/ludevdot/pi-hud/issues"
  },
  "packageManager": "pnpm@11.4.0",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "hud",
    "statusline",
    "terminal-hud",
    "terminal-overlay",
    "mcp",
    "subagents",
    "context",
    "git-status",
    "coding-agent"
  ],
  "files": [
    "extensions",
    "skills",
    "assets/pi-hud.jpeg",
    "assets/hud.png",
    "assets/release-notes.json",
    "README.md",
    "CHANGELOG.md",
    "RELEASING.md",
    "LICENSE",
    "scripts"
  ],
  "scripts": {
    "test": "vitest --run",
    "pack:dry": "pnpm pack --dry-run",
    "verify:package": "node scripts/verify-package-files.mjs",
    "generate:release-notes": "node scripts/generate-release-notes.mjs",
    "changeset": "changeset",
    "version:changeset": "changeset version",
    "release:check": "pnpm run pack:dry",
    "prepack": "pnpm test && pnpm run verify:package",
    "prepublishOnly": "pnpm test && pnpm run verify:package"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "image": "https://cdn.jsdelivr.net/npm/pi-hud/assets/pi-hud.jpeg"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@earendil-works/pi-ai": "0.77.0",
    "@earendil-works/pi-coding-agent": "0.77.0",
    "@earendil-works/pi-tui": "0.77.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
